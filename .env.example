# --- LLM keys (any ONE enables grounded answers; otherwise retrieval-only) ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# auto | openai | gemini
LLM_PROVIDER=auto
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash

# Embedding model (SentenceTransformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Service endpoints
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
